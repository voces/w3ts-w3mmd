{
  "name": "w3ts-w3mmd",
  "version": "2.2.2",
  "description": "w3mmd extension for w3ts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "tstl": "./dist/index",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:js": "tsc -p tsconfig.dist.json",
    "build:lua": "tstl",
    "build": "npm run build:lua && npm run build:js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:voces/w3ts-w3mmd.git"
  },
  "devDependencies": {
    "lua-types": "^2.14.1",
    "typescript": "6.0.2",
    "typescript-to-lua": "^1.36.0",
    "war3-types-strict": "^0.1.3"
  },
  "author": "Robert Coe",
  "license": "ISC",
  "keywords": [
    "warcraft",
    "wc3",
    "typescript",
    "ts",
    "w3ts"
  ]
}
